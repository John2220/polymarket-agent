# === Polymarket ===
POLYMARKET_PRIVATE_KEY=       # Нужен только для авто-режима
POLYMARKET_FUNDER_ADDRESS=    # Нужен только для авто-режима

# === Котировки букмекеров ===
ODDS_API_KEY=                 # the-odds-api.com (бесплатно 500 запр/мес)
FOOTBALL_DATA_API_KEY=        # football-data.org (10 запр/мин, для фильтра формы команды)
# Список лиг: JSON-массив (так ожидает pydantic-settings) или задайте в коде по умолчанию
SPORTS=["basketball_nba","soccer_epl","soccer_uefa_champs_league","soccer_mexico_ligamx","mma_mixed_martial_arts"]

# === Стратегия ===
KELLY_MULTIPLIER=0.25         # Доля от оптимальной ставки Келли
MIN_EDGE=0.03                 # Минимальное преимущество 3% (только реальный edge от Pinnacle)
MIN_LIQUIDITY=1000            # Мин. ликвидность рынка $1000
NO_BET_MAX_YES=0.65           # Запрет NO если YES>65% (ставка против рынка)

# === Лимиты ===
MAX_BET_PCT=0.05              # Макс. 5% банкролла на ставку
MAX_BET_USD=50                # Макс. $50 на ставку
MAX_SLIPPAGE=0.02             # Макс. проскальзывание 2%
DAILY_LOSS_LIMIT=50           # Стоп-лосс $50 в день (только mode=auto, дата UTC)
MAX_DAILY_WAGER_PCT=0.30      # Макс. доля банкролла в обороте за сутки (UTC, только auto)
MAX_CONSECUTIVE_LOSSES=3      # Пауза после 3 проигрышей подряд (auto, только pnl<0)

# === Инфраструктура ===
POLL_INTERVAL=60              # Секунды между сканированиями

# === Исполнение ордеров (auto mode) ===
USE_MAKER_FIRST=false         # true = GTC post-only, лимит у best_bid+N тиков
MAKER_TICK_OFFSET=1
MAKER_TICK_SIZE=0.01

# === Kalshi (каркас task-kalshi-cross-venue) ===
# KALSHI_API_KEY=

# === refresh.py (Excel; опционально) ===
# По умолчанию Excel: polymarket_рекомендации.xlsx в корне репозитория
# REFRESH_EXCEL_PATH=polymarket_рекомендации.xlsx
# Кэш рынков для вкладки «Рекомендации»: несколько файлов через ; (JSON или .txt с JSON)
# REFRESH_MARKET_CACHE_FILES=C:\path\to\cache1.json;C:\path\to\cache2.txt
# Или каталог с *.json / *.txt:
# REFRESH_MARKET_CACHE_DIR=data/market_cache
